# Enclave-bound signing key. Generate: npm run verify keygen
# On EigenCompute set it as a SEALED secret: ecloud compute app env set WAYBILL_SIGNER_KEY=0x...
WAYBILL_SIGNER_KEY=

# Sepolia RPC for on-chain anchoring. Unset = local mode (no anchoring).
WAYBILL_RPC_URL=

# Set at deploy to the image digest recorded on-chain (AppController).
IMAGE_DIGEST=

# Model provider. Set ONE of these for real routing; unset = mock mode.
#   SAKANA_API_KEY     → native Fugu (https://api.sakana.ai/v1), models: fugu, fugu-ultra
#   OPENROUTER_API_KEY → OpenRouter (https://openrouter.ai/api/v1), serves sakana/fugu-ultra
SAKANA_API_KEY=
OPENROUTER_API_KEY=
# Base URL override (else inferred from the key above).
FUGU_API_URL=
# Optional: map router model ids -> provider model ids, e.g.
# FUGU_MODEL_MAP={"fugu":"sakana/fugu-ultra","fugu-ultra":"sakana/fugu-ultra"}
FUGU_MODEL_MAP=
